# ────────────────────────────────────────────────────────────────────────────
# SHAPIO — Environment Variables
# Copy this file to .env.local and fill in all values.
# NEVER commit .env.local to git.
# ────────────────────────────────────────────────────────────────────────────

# App URL — IMPORTANT: change this on Vercel to your production domain
# Local:      http://localhost:3000
# Production: https://yourdomain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Supabase ────────────────────────────────────────────────────────────────
# Get from: supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Stripe ──────────────────────────────────────────────────────────────────
# Use test keys (pk_test_, sk_test_) for development
# Use live keys (pk_live_, sk_live_) for production
# Get from: dashboard.stripe.com → Developers → API keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...

# Webhook secret — from Stripe CLI (dev) or Stripe dashboard (production)
# Dev:  stripe listen --forward-to localhost:3000/api/stripe/webhook
# Prod: Add endpoint https://yourdomain.com/api/stripe/webhook in Stripe dashboard
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs — create recurring monthly prices in CZK in Stripe dashboard
# ALL plans are now monthly recurring subscriptions (Elite was one-time, now monthly)
STRIPE_PRICE_STARTER_MONTHLY=price_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_ELITE_MONTHLY=price_...

# ─── OpenAI ──────────────────────────────────────────────────────────────────
# Get from: platform.openai.com → API keys
OPENAI_API_KEY=sk-...
